                      size="large"
                      prefix={<LineChartOutlined />}
                      onBlur={(e) => {
                        if (e.target.value) {
                          form.setFieldsValue({ symbol: e.target.value.toUpperCase() });
                        }
                      }}
                    />
                  </Form.Item>
                </Col>
                <Col span={12}>
                  <Form.Item
                    label="Strategy"
                    name="strategy"
                    rules={[{ required: true, message: 'Please select a strategy' }]}
                  >
                    <Select size="large" placeholder="Select strategy">
                      {strategyOptions.map(option => (
                        <Option key={option.value} value={option.value}>
                          {option.label} {option.type === 'simulated' ? '(Simulated)' : '(Real)'}
                        </Option>
                      ))}
                    </Select>
                  </Form.Item>
                </Col>
              </Row>
              
              <Row gutter={16}>
                <Col span={12}>
                  <Form.Item
                    label="Date Range"
                    name="dateRange"
                    rules={[{ required: true, message: 'Please select date range' }]}
                    help="Default: Last 1 year"
                  >
                    <RangePicker size="large" style={{ width: '100%' }} />
                  </Form.Item>
                </Col>
                <Col span={12}>
                  <Form.Item
                    label="Initial Capital ($)"
                    name="initialCapital"
                    rules={[
                      { required: true, message: 'Please enter initial capital' },
                      { type: 'number', min: 1000, message: 'Minimum $1,000' },
                    ]}
                    help="Minimum: $1,000"
                  >
                    <InputNumber
                      min={1000}
                      size="large"
                      style={{ width: '100%' }}
                    />
                  </Form.Item>
                </Col>
              </Row>
              
              {/* Parameter Optimization Panel (only shown for moving_average strategy) */}
              {form.getFieldValue('strategy') === 'moving_average' && (
                <div style={{ marginBottom: 16 }}>
                  <div 
                    style={{ 
                      display: 'flex', 
                      alignItems: 'center', 
                      cursor: 'pointer',
                      padding: '12px',
                      background: showOptimization ? '#f0f7ff' : '#fafafa',
                      borderRadius: '4px',
                      border: `1px solid ${showOptimization ? '#1890ff' : '#e8e8e8'}`,
                      marginBottom: showOptimization ? 8 : 0,
                      transition: 'all 0.2s'
                    }}
                    onClick={() => {
                      console.log('=== CLICK: Advanced: Parameter Optimization ===');
                      console.log('Current showOptimization:', showOptimization);
                      console.log('Setting to:', !showOptimization);
                      setShowOptimization(!showOptimization);
                    }}
                  >
                    <DownOutlined style={{ 
                      marginRight: 8, 
                      transform: showOptimization ? 'rotate(180deg)' : 'rotate(0deg)',
                      transition: 'transform 0.2s',
                      color: showOptimization ? '#1890ff' : '#666'
                    }} />
                    <span style={{ 
                      fontWeight: 600, 
                      fontSize: '14px',
                      color: showOptimization ? '#1890ff' : '#333'
                    }}>
                      Advanced: Parameter Optimization {showOptimization ? '(Expanded)' : '(Click to expand)'}
                    </span>
                  </div>
                  
                  {showOptimization && (
                    <div style={{ 
                      padding: '16px', 
                      background: '#fafafa', 
                      borderRadius: '4px',
                      marginTop: '8px'
                    }}>
                      <div style={{ marginBottom: 16 }}>
                        <h4 style={{ marginBottom: 8 }}>Moving Average Parameters</h4>
                        <p style={{ color: '#666', fontSize: '12px', marginBottom: 16 }}>
                          Configure parameter ranges for optimization. Maximum 50 valid combinations.
                        </p>
                      </div>
                      
                      <Row gutter={16}>
                        <Col span={12}>
                          <div style={{ marginBottom: 16 }}>
                            <h5 style={{ marginBottom: 8 }}>Short MA (fast)</h5>
                            <Row gutter={8}>
                              <Col span={8}>
                                <Form.Item
                                  label="Min"
                                  name="shortMin"
                                  initialValue={5}
                                  rules={[
                                    { required: true, message: 'Required' },
                                    { type: 'number', min: 1, message: 'Min 1' }
                                  ]}
                                >
                                  <InputNumber min={1} style={{ width: '100%' }} />
                                </Form.Item>
                              </Col>
                              <Col span={8}>
                                <Form.Item
                                  label="Max"
                                  name="shortMax"
                                  initialValue={20}
                                  rules={[
                                    { required: true, message: 'Required' },
                                    { type: 'number', min: 1, message: 'Min 1' }
                                  ]}
                                >
                                  <InputNumber min={1} style={{ width: '100%' }} />
                                </Form.Item>
                              </Col>
                              <Col span={8}>
                                <Form.Item
                                  label="Step"
                                  name="shortStep"
                                  initialValue={5}
                                  rules={[
                                    { required: true, message: 'Required' },
                                    { type: 'number', min: 1, message: 'Min 1' }
                                  ]}
                                >
                                  <InputNumber min={1} style={{ width: '100%' }} />
                                </Form.Item>
                              </Col>
                            </Row>
                          </div>
                        </Col>
                        
                        <Col span={12}>
                          <div style={{ marginBottom: 16 }}>
                            <h5 style={{ marginBottom: 8 }}>Long MA (slow)</h5>
                            <Row gutter={8}>
                              <Col span={8}>
                                <Form.Item
                                  label="Min"
                                  name="longMin"
                                  initialValue={50}
                                  rules={[
                                    { required: true, message: 'Required' },
                                    { type: 'number', min: 1, message: 'Min 1' }
                                  ]}
                                >
                                  <InputNumber min={1} style={{ width: '100%' }} />
                                </Form.Item>
                              </Col>
                              <Col span={8}>
                                <Form.Item
                                  label="Max"
                                  name="longMax"
                                  initialValue={100}
                                  rules={[
                                    { required: true, message: 'Required' },
                                    { type: 'number', min: 1, message: 'Min 1' }
                                  ]}
                                >
                                  <InputNumber min={1} style={{ width: '100%' }} />
                                </Form.Item>
                              </Col>
                              <Col span={8}>
                                <Form.Item
                                  label="Step"
                                  name="longStep"
                                  initialValue={50}
                                  rules={[
                                    { required: true, message: 'Required' },
                                    { type: 'number', min: 1, message: 'Min 1' }
                                  ]}
                                >
                                  <InputNumber min={1} style={{ width: '100%' }} />
                                </Form.Item>
                              </Col>
                            </Row>
                          </div>
                        </Col>
                      </Row>
                      
                      {optimizationError && (
                        <Alert
                          message="Optimization Error"
                          description={optimizationError}
                          type="error"
                          showIcon
                          style={{ marginBottom: 16 }}
                          closable
                          onClose={() => setOptimizationError('')}
                        />
                      )}
                    </div>
                  )}
                </div>
              )}
              
              <Form.Item>
                <Row gutter={16}>
                  <Col span={form.getFieldValue('strategy') === 'moving_average' ? 12 : 24}>
                    <Button
                      type="primary"
                      htmlType="submit"
                      size="large"
                      loading={loading}
                      icon={<PlayCircleOutlined />}
                      style={{ width: '100%' }}
                      disabled={loading}
                    >
                      {loading ? 'Running Backtest...' : 'Run Backtest'}
                    </Button>
                  </Col>
                  
                  {form.getFieldValue('strategy') === 'moving_average' && (
                    <Col span={12}>
                      <Button
                        type="default"
                        htmlType="button"  // æįĄŪčŪūį―Ūäļ?buttonïžéēæ­Ēč§ĶåčĄĻåæäš?                        size="large"
                        loading={optimizationLoading}
                        icon={<ExperimentOutlined />}
                        style={{ width: '100%' }}
                        disabled={optimizationLoading || loading}
                        onClick={(e) => {
                          e.preventDefault(); // éēæ­ĒéŧčŪĪčĄäļš
                          e.stopPropagation(); // éŧæ­ĒäšäŧķåæģĄ
                          
                          console.log('=== OPTIMIZATION BUTTON CLICKED ===');
                          const currentStrategy = form.getFieldValue('strategy');
                          
                          // Check if strategy is moving_average
                          if (currentStrategy !== 'moving_average') {
                            message.error('Parameter optimization is only available for Moving Average strategy');
                            return;
                          }
                          
                          // Get form values and run optimization
                          // Use getFieldsValue to get all form values, not just validated ones
                          const formValues = form.getFieldsValue();
                          console.log('=== FORM VALUES ===');
                          console.log('All form values:', formValues);
                          console.log('Optimization parameters:');
                          console.log('  shortMin:', formValues.shortMin);
                          console.log('  shortMax:', formValues.shortMax);
                          console.log('  shortStep:', formValues.shortStep);
                          console.log('  longMin:', formValues.longMin);
                          console.log('  longMax:', formValues.longMax);
                          console.log('  longStep:', formValues.longStep);
                          
                          // Check if optimization parameters are filled
                          // Use default values if not provided
                          const shortMin = formValues.shortMin || 5;
                          const shortMax = formValues.shortMax || 20;
                          const shortStep = formValues.shortStep || 5;
                          const longMin = formValues.longMin || 50;
                          const longMax = formValues.longMax || 100;
                          const longStep = formValues.longStep || 50;
                          
                          console.log('Using parameters:');
                          console.log('  short_ma:', { min: shortMin, max: shortMax, step: shortStep });
                          console.log('  long_ma:', { min: longMin, max: longMax, step: longStep });
                          
                          // Create values object with defaults
                          const valuesWithDefaults = {
                            ...formValues,
                            shortMin,
                            shortMax,
                            shortStep,
                            longMin,
                            longMax,
                            longStep
                          };
                          
                          console.log('Starting optimization with values:', valuesWithDefaults);
                          handleRunOptimization(valuesWithDefaults);
                        }}
                      >
                        {optimizationLoading ? 'Running Optimization...' : 'Run Parameter Optimization'}
                      </Button>
                    </Col>
                  )}
                </Row>
              </Form.Item>
            </Form>
          </Card>
          
          {backtestResult && (
            <div ref={resultsRef}>
              <Card title="Backtest Results" style={{ marginTop: 16 }}>
                <Tabs
                  defaultActiveKey="results"
                  items={[
                    {
                      key: 'results',
                      label: 'Results Table',
                      children: (
                        <>
                          <Table
                            columns={resultColumns}
                            dataSource={resultData}
                            pagination={false}
                            size="small"
                          />
                          
                          <Divider />
                          
                          {/* Benchmark Comparison */}
                          {backtestResult?.results?.buyHoldReturn !== undefined && backtestResult?.results?.buyHoldEquitySeries && (
                            <>
                              <h4 style={{ marginBottom: '16px' }}>Benchmark Comparison</h4>
                              <div style={{ 
                                background: '#fafafa',
                                borderRadius: '8px',
                                padding: '20px',
                                marginBottom: '24px'
                              }}>
                                {/* Return Comparison */}
                                <div style={{ marginBottom: '20px' }}>
                                  <h5 style={{ marginBottom: '12px', color: '#333' }}>Return Comparison</h5>
                                  <div style={{ 
                                    display: 'grid', 
                                    gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))',
                                    gap: '16px'
                                  }}>
                                    <div style={{ 
                                      background: 'white',
                                      padding: '16px',
                                      borderRadius: '6px',
                                      border: '1px solid #e8e8e8'
                                    }}>
                                      <div style={{ fontSize: '12px', color: '#666', marginBottom: '4px' }}>Strategy Return</div>
                                      <div style={{ 
                                        fontSize: '20px', 
                                        fontWeight: '600',
                                        color: (backtestResult.results?.totalReturn || 0) >= 0 ? '#3f8600' : '#cf1322'
                                      }}>
                                        {formatPercent(backtestResult.results?.totalReturn)}
                                      </div>
                                    </div>
                                    
                                    <div style={{ 
                                      background: 'white',
                                      padding: '16px',
                                      borderRadius: '6px',
                                      border: '1px solid #e8e8e8'
                                    }}>
                                      <div style={{ fontSize: '12px', color: '#666', marginBottom: '4px' }}>Buy & Hold Return</div>
                                      <div style={{ 
                                        fontSize: '20px', 
                                        fontWeight: '600',
                                        color: (backtestResult.results?.buyHoldReturn || 0) >= 0 ? '#3f8600' : '#cf1322'
                                      }}>
                                        {formatPercent(backtestResult.results?.buyHoldReturn)}
                                      </div>
                                    </div>
                                    
                                    <div style={{ 
                                      background: 'white',
                                      padding: '16px',
                                      borderRadius: '6px',
                                      border: '1px solid #e8e8e8'
                                    }}>
                                      <div style={{ fontSize: '12px', color: '#666', marginBottom: '4px' }}>Excess Return</div>
                                      <div style={{ 
                                        fontSize: '20px', 
                                        fontWeight: '600',
                                        color: ((backtestResult.results?.totalReturn || 0) - (backtestResult.results?.buyHoldReturn || 0)) >= 0 ? '#3f8600' : '#cf1322'
                                      }}>
                                        {formatPercent((backtestResult.results?.totalReturn || 0) - (backtestResult.results?.buyHoldReturn || 0))}
                                      </div>
                                    </div>
                                  </div>
                                </div>
                                
                                {/* Equity Comparison Chart */}
                                <div>
                                  <h5 style={{ marginBottom: '12px', color: '#333' }}>Equity Comparison</h5>
                                  <div style={{ 
                                    height: '200px', 
                                    background: 'white',
                                    borderRadius: '6px',
                                    padding: '16px',
                                    border: '1px solid #e8e8e8'
                                  }}>
                                    {(() => {
                                      const strategyEquityData = equityCurveData;
                                      const buyHoldEquityData = backtestResult.results?.buyHoldEquitySeries || [];
                                      
                                      if (strategyEquityData.length === 0 || buyHoldEquityData.length === 0) {
                                        return (
                                          <div style={{
                                            height: '100%',
                                            display: 'flex',
                                            alignItems: 'center',
                                            justifyContent: 'center',
                                            color: '#999',
                                            fontSize: '12px'
                                          }}>
                                            No equity data available
                                          </div>
                                        );
                                      }
                                      
                                      // Prepare data for Recharts
                                      // We need to combine both datasets into a single array
                                      // First, create a map of dates to ensure we have all dates
                                      const dateMap = new Map();
                                      
                                      // Add strategy equity data
                                      strategyEquityData.forEach(item => {
                                        dateMap.set(item.date, {
                                          date: item.date,
                                          strategy: item.equity,
                                          buyHold: null
                                        });
                                      });
                                      
                                      // Add buy & hold equity data
                                      buyHoldEquityData.forEach(item => {
                                        if (dateMap.has(item.date)) {
                                          dateMap.get(item.date).buyHold = item.equity;
                                        } else {
                                          dateMap.set(item.date, {
                                            date: item.date,
                                            strategy: null,
                                            buyHold: item.equity
                                          });
                                        }
                                      });
                                      
                                      // Convert to array and sort by date
                                      const equityComparisonData = Array.from(dateMap.values())
                                        .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
                                      
                                      // Fill missing values with linear interpolation
                                      for (let i = 0; i < equityComparisonData.length; i++) {
                                        if (equityComparisonData[i].strategy === null && i > 0 && i < equityComparisonData.length - 1) {
                                          // Find nearest strategy values
                                          let prevStrategy = null;
                                          let nextStrategy = null;
                                          for (let j = i - 1; j >= 0; j--) {
                                            if (equityComparisonData[j].strategy !== null) {
                                              prevStrategy = equityComparisonData[j].strategy;
                                              break;
                                            }
                                          }
                                          for (let j = i + 1; j < equityComparisonData.length; j++) {
                                            if (equityComparisonData[j].strategy !== null) {
                                              nextStrategy = equityComparisonData[j].strategy;
                                              break;
                                            }
                                          }
                                          if (prevStrategy !== null && nextStrategy !== null) {
                                            equityComparisonData[i].strategy = prevStrategy;
                                          }
                                        }
                                        
                                        if (equityComparisonData[i].buyHold === null && i > 0 && i < equityComparisonData.length - 1) {
                                          // Find nearest buyHold values
                                          let prevBuyHold = null;
                                          let nextBuyHold = null;
                                          for (let j = i - 1; j >= 0; j--) {
                                            if (equityComparisonData[j].buyHold !== null) {
                                              prevBuyHold = equityComparisonData[j].buyHold;
                                              break;
                                            }
                                          }
                                          for (let j = i + 1; j < equityComparisonData.length; j++) {
                                            if (equityComparisonData[j].buyHold !== null) {
                                              nextBuyHold = equityComparisonData[j].buyHold;
                                              break;
                                            }
                                          }
                                          if (prevBuyHold !== null && nextBuyHold !== null) {
                                            equityComparisonData[i].buyHold = prevBuyHold;
                                          }
                                        }
                                      }
                                      
                                      return (
                                        <ResponsiveContainer width="100%" height="100%">
                                          <LineChart
                                            data={equityComparisonData}
                                            margin={{ top: 5, right: 5, left: 5, bottom: 5 }}
                                          >
                                            <CartesianGrid strokeDasharray="3 3" stroke="#f0f0f0" />
                                            <XAxis 
                                              dataKey="date" 
                                              tick={{ fontSize: 10 }}
                                              tickFormatter={(value) => {
                                                // Format date to show only month/day for better readability
                                                const date = new Date(value);
                                                return `${date.getMonth() + 1}/${date.getDate()}`;
                                              }}
                                            />
                                            <YAxis 
                                              tick={{ fontSize: 10 }}
                                              tickFormatter={(value) => `$${value.toFixed(0)}`}
                                            />
                                            <RechartsTooltip 
                                              formatter={(value, name) => {
                                                if (name === 'strategy') return [`$${Number(value).toFixed(2)}`, 'Strategy Equity'];
                                                if (name === 'buyHold') return [`$${Number(value).toFixed(2)}`, 'Buy & Hold Equity'];
                                                return [value, name];
                                              }}
                                              labelFormatter={(label) => `Date: ${label}`}
                                            />
                                            <Legend 
                                              wrapperStyle={{ fontSize: '12px', paddingTop: '5px' }}
                                              formatter={(value) => {
                                                if (value === 'strategy') return 'Strategy Equity';
                                                if (value === 'buyHold') return 'Buy & Hold Equity';
                                                return value;
                                              }}
                                            />
                                            <Line
                                              type="monotone"
                                              dataKey="strategy"
                                              stroke="#1890ff"
                                              strokeWidth={2}
                                              dot={false}
                                              activeDot={{ r: 4 }}
                                              name="strategy"
                                            />
                                            <Line
                                              type="monotone"
                                              dataKey="buyHold"
                                              stroke="#52c41a"
                                              strokeWidth={2}
                                              strokeDasharray="5 5"
                                              dot={false}
                                              activeDot={{ r: 4 }}
                                              name="buyHold"
                                            />
                                          </LineChart>
                                        </ResponsiveContainer>
                                      );
                                    })()}
                                  </div>
                                  
                                  {/* Performance Summary */}
                                  <div style={{ 
                                    marginTop: '16px',
                                    fontSize: '12px',
                                    color: '#666',
                                    textAlign: 'center'
                                  }}>
                                    {((backtestResult.results?.totalReturn || 0) > (backtestResult.results?.buyHoldReturn || 0)) ? (
                                      <span style={{ color: '#3f8600' }}>
                                        Strategy outperforms Buy & Hold by {formatPercent((backtestResult.results?.totalReturn || 0) - (backtestResult.results?.buyHoldReturn || 0))}
                                      </span>
                                    ) : (
                                      <span style={{ color: '#cf1322' }}>
                                        Strategy underperforms Buy & Hold by {formatPercent(Math.abs((backtestResult.results?.totalReturn || 0) - (backtestResult.results?.buyHoldReturn || 0)))}
                                      </span>
                                    )}
                                  </div>
                                </div>
                              </div>
                              
                              <Divider />
                            </>
                          )}
                          
                          {/* Parameter Optimization Results */}
                          {optimizationResult && optimizationResult.success && (
                            <div style={{ marginTop: '32px' }}>
                              <h4 style={{ marginBottom: '24px' }}>Parameter Optimization Results</h4>
                              
                              {/* Best Combination Summary */}
                              <Card style={{ marginBottom: '24px' }}>
                                <div style={{ marginBottom: '16px', fontSize: '16px', fontWeight: '600', color: '#333' }}>
                                  Optimization Summary
                                </div>
                                <Row gutter={[24, 24]}>
                                  <Col span={4}>
                                    <div style={{ textAlign: 'center' }}>
                                      <div style={{ fontSize: '24px', fontWeight: '600', color: '#1890ff', marginBottom: '4px' }}>
                                        {optimizationResult.totalCombinations}
                                      </div>
                                      <div style={{ fontSize: '12px', color: '#666' }}>
                                        Total Combinations
                                      </div>
                                    </div>
                                  </Col>
                                  <Col span={4}>
                                    <div style={{ textAlign: 'center' }}>
                                      <div style={{ fontSize: '24px', fontWeight: '600', color: '#52c41a', marginBottom: '4px' }}>
                                        {optimizationResult.validCombinations}
                                      </div>
                                      <div style={{ fontSize: '12px', color: '#666' }}>
                                        Valid Results
                                      </div>
                                    </div>
                                  </Col>
                                  <Col span={4}>
                                    <div style={{ textAlign: 'center' }}>
                                      <div style={{ fontSize: '24px', fontWeight: '600', color: '#3f8600', marginBottom: '4px' }}>
                                        {formatPercent(optimizationResult.bestCombination.totalReturn)}
                                      </div>
                                      <div style={{ fontSize: '12px', color: '#666' }}>
                                        Best Return
                                      </div>
                                    </div>
                                  </Col>
                                  <Col span={4}>
                                    <div style={{ textAlign: 'center' }}>
                                      <div style={{ fontSize: '24px', fontWeight: '600', color: '#cf1322', marginBottom: '4px' }}>
                                        {(() => {
                                          // Find worst return from all results
                                          const worstReturn = Math.min(...optimizationResult.results.map((r: OptimizationResult) => r.totalReturn));
                                          return formatPercent(worstReturn);
                                        })()}
                                      </div>
                                      <div style={{ fontSize: '12px', color: '#666' }}>
                                        Worst Return
                                      </div>
                                    </div>
                                  </Col>
                                  <Col span={4}>
                                    <div style={{ textAlign: 'center' }}>
                                      <div style={{ fontSize: '24px', fontWeight: '600', color: '#fa8c16', marginBottom: '4px' }}>
                                        {(() => {
                                          // Calculate average return
                                          const avgReturn = optimizationResult.results.reduce((sum: number, r: OptimizationResult) => sum + r.totalReturn, 0) / optimizationResult.results.length;
                                          return formatPercent(avgReturn);
                                        })()}
                                      </div>
                                      <div style={{ fontSize: '12px', color: '#666' }}>
                                        Average Return
                                      </div>
                                    </div>
                                  </Col>
                                  <Col span={4}>
                                    <div style={{ textAlign: 'center' }}>
                                      <div style={{ fontSize: '24px', fontWeight: '600', color: '#ffd700', marginBottom: '4px' }}>
                                        {optimizationResult.bestCombination.short_ma}/{optimizationResult.bestCombination.long_ma}
                                      </div>
                                      <div style={{ fontSize: '12px', color: '#666' }}>
                                        Top Combination
                                      </div>
                                    </div>
                                  </Col>
                                </Row>
                              </Card>

                              {/* Optimization Heatmap */}
                              <Card style={{ marginBottom: '24px' }}>
                                <h3 style={{ marginBottom: '16px' }}>Optimization Heatmap</h3>
                                <div style={{ 
                                  background: 'white',
                                  borderRadius: '8px',
                                  padding: '20px',
                                  border: '1px solid #e8e8e8',
                                  display: 'flex',
                                  flexDirection: 'column',
                                  alignItems: 'center'
                                }}>
                                  <div style={{ marginBottom: '16px', fontSize: '12px', color: '#666', textAlign: 'center' }}>
                                    X-axis: Short MA (fast), Y-axis: Long MA (slow). Color represents Sharpe Ratio.
                                  </div>
                                  <OptimizationHeatmap results={optimizationResult.results} />
                                </div>
                              </Card>

                              {/* Optimization Results Table */}
                              <Card title="Optimization Results">
                                <Table
                                  columns={[
                                    {
                                      title: 'Rank',
                                      dataIndex: 'rank',
                                      key: 'rank',
                                      width: 80,
                                      render: (rank: number) => (
                                        <div style={{ 
                                          display: 'flex', 
                                          alignItems: 'center', 
                                          justifyContent: 'center',
                                          fontWeight: 'bold',
                                          fontSize: rank === 1 ? '16px' : '14px',
                                          color: rank === 1 ? '#ffd700' : rank === 2 ? '#c0c0c0' : rank === 3 ? '#cd7f32' : '#666'
                                        }}>
                                          {rank}
                                        </div>
                                      ),
                                    },
                                    {
                                      title: 'Short MA',
                                      dataIndex: 'short_ma',
                                      key: 'short_ma',
                                      width: 90,
                                      render: (value: number) => (
                                        <Tag color="blue" style={{ fontWeight: 'bold' }}>
                                          {value}
                                        </Tag>
                                      ),
                                    },
                                    {
                                      title: 'Long MA',
                                      dataIndex: 'long_ma',
                                      key: 'long_ma',
                                      width: 90,
                                      render: (value: number) => (
                                        <Tag color="green" style={{ fontWeight: 'bold' }}>
                                          {value}
                                        </Tag>
                                      ),
                                    },
                                    {
                                      title: 'Total Return',
                                      dataIndex: 'totalReturn',
                                      key: 'totalReturn',
                                      width: 120,
                                      defaultSortOrder: 'descend' as const,
                                      sorter: (a: OptimizationResult, b: OptimizationResult) => a.totalReturn - b.totalReturn,
                                      render: (value: number) => {
                                        const color = value >= 0 ? '#3f8600' : '#cf1322';
                                        return (
                                          <span style={{ color, fontWeight: 'bold', fontSize: '14px' }}>
                                            {formatPercent(value)}
                                          </span>
                                        );
                                      },
                                    },
                                    {
                                      title: 'Annualized',
                                      dataIndex: 'annualizedReturn',
                                      key: 'annualizedReturn',
                                      width: 120,
                                      sorter: (a: OptimizationResult, b: OptimizationResult) => a.annualizedReturn - b.annualizedReturn,
                                      render: (value: number) => {
                                        const color = value >= 0 ? '#3f8600' : '#cf1322';
                                        return (
                                          <span style={{ color, fontWeight: 'bold' }}>
                                            {formatPercent(value)}
                                          </span>
                                        );
                                      },
                                    },
                                    {
                                      title: 'Sharpe',
                                      dataIndex: 'sharpeRatio',
                                      key: 'sharpeRatio',
                                      width: 90,
                                      sorter: (a: OptimizationResult, b: OptimizationResult) => a.sharpeRatio - b.sharpeRatio,
                                      render: (value: number) => {
                                        const color = value >= 1 ? '#3f8600' : value >= 0 ? '#fa8c16' : '#cf1322';
                                        return (
                                          <span style={{ color, fontWeight: 'bold' }}>
                                            {value.toFixed(2)}
                                          </span>
                                        );
                                      },
                                    },
                                    {
                                      title: 'Max DD',
                                      dataIndex: 'maxDrawdown',
                                      key: 'maxDrawdown',
                                      width: 90,
                                      sorter: (a: OptimizationResult, b: OptimizationResult) => a.maxDrawdown - b.maxDrawdown,
                                      render: (value: number) => {
                                        let color = '#cf1322'; // éŧčŪĪįšĒčē
                                        if (value > -20) {
                                          color = '#3f8600'; // įŧŋčē
                                        } else if (value >= -40) {
                                          color = '#fa8c16'; // æĐčē
                                        }
                                        return (
                                          <span style={{ color, fontWeight: 'bold' }}>
                                            {value.toFixed(1)}%
                                          </span>
                                        );
                                      },
                                    },
                                    {
                                      title: 'Trades',
                                      dataIndex: 'trades',
                                      key: 'trades',
                                      width: 80,
                                      sorter: (a: OptimizationResult, b: OptimizationResult) => a.trades - b.trades,
                                      render: (value: number) => (
                                        <span style={{ fontWeight: 'bold' }}>
                                          {Math.round(value)}
                                        </span>
                                      ),
                                    },
                                  ]}
                                  dataSource={optimizationResult.results}
                                  pagination={{
                                    pageSize: 10,
                                    showSizeChanger: true,
                                    showQuickJumper: true,
                                    showTotal: (total, range) => `${range[0]}-${range[1]} of ${total} combinations`,
                                  }}
                                  size="middle"
                                  scroll={{ x: 800 }}
                                  bordered
                                  rowClassName={(record, index) => 
                                    index === 0 ? 'top-rank-row' : index === 1 ? 'second-rank-row' : index === 2 ? 'third-rank-row' : ''
                                  }
                                />
                              </Card>
                            </div>
                          )}
                              
                              {/* Best Combination Summary */}
                              <div style={{ 
                                background: '#fafafa',
                                borderRadius: '8px',
                                padding: '20px',
                                marginBottom: '24px',
                                border: '1px solid #e8e8e8'
                              }}>
                                <h5 style={{ marginBottom: '16px', color: '#1890ff' }}>Best Combination Summary</h5>
                                
                                <Row gutter={[16, 16]}>
                                  <Col span={8}>
                                    <div style={{ textAlign: 'center' }}>
                                      <div style={{ fontSize: '12px', color: '#666', marginBottom: '4px' }}>Short MA</div>
                                      <div style={{ fontSize: '20px', fontWeight: 'bold' }}>
                                        {optimizationResult.bestCombination.short_ma}
                                      </div>
                                    </div>
                                  </Col>
                                  <Col span={8}>
                                    <div style={{ textAlign: 'center' }}>
                                      <div style={{ fontSize: '12px', color: '#666', marginBottom: '4px' }}>Long MA</div>
                                      <div style={{ fontSize: '20px', fontWeight: 'bold' }}>
                                        {optimizationResult.bestCombination.long_ma}
                                      </div>
                                    </div>
                                  </Col>
                                  <Col span={8}>
                                    <div style={{ textAlign: 'center' }}>
                                      <div style={{ fontSize: '12px', color: '#666', marginBottom: '4px' }}>Trades</div>
                                      <div style={{ fontSize: '20px', fontWeight: 'bold' }}>
                                        {optimizationResult.bestCombination.trades}
                                      </div>
                                    </div>
                                  </Col>
                                </Row>
                                
                                <Divider style={{ margin: '16px 0' }} />
                                
                                <Row gutter={[16, 16]}>
                                  <Col span={8}>
                                    <div style={{ textAlign: 'center' }}>
                                      <div style={{ fontSize: '12px', color: '#666', marginBottom: '4px' }}>Sharpe Ratio</div>
                                      <div style={{ 
                                        fontSize: '20px', 
                                        fontWeight: 'bold',
                                        color: optimizationResult.bestCombination.sharpeRatio >= 0 ? '#52c41a' : '#ff4d4f'
                                      }}>
                                        {optimizationResult.bestCombination.sharpeRatio.toFixed(2)}
                                      </div>
                                    </div>
                                  </Col>
                                  <Col span={8}>
                                    <div style={{ textAlign: 'center' }}>
                                      <div style={{ fontSize: '12px', color: '#666', marginBottom: '4px' }}>Total Return</div>
                                      <div style={{ 
                                        fontSize: '20px', 
                                        fontWeight: 'bold',
                                        color: optimizationResult.bestCombination.totalReturn >= 0 ? '#52c41a' : '#ff4d4f'
                                      }}>
                                        {optimizationResult.bestCombination.totalReturn >= 0 ? '+' : ''}{optimizationResult.bestCombination.totalReturn.toFixed(2)}%
                                      </div>
                                    </div>
                                  </Col>
                                  <Col span={8}>
                                    <div style={{ textAlign: 'center' }}>
                                      <div style={{ fontSize: '12px', color: '#666', marginBottom: '4px' }}>Max Drawdown</div>
                                      <div style={{ 
                                        fontSize: '20px', 
                                        fontWeight: 'bold',
                                        color: '#ff4d4f'
                                      }}>
                                        {optimizationResult.bestCombination.maxDrawdown.toFixed(2)}%
                                      </div>
                                    </div>
                                  </Col>
                                </Row>
                                
                                <div style={{ 
                                  marginTop: '16px', 
                                  padding: '12px',
                                  background: '#e6f7ff',
                                  borderRadius: '4px',
                                  fontSize: '12px',
                                  color: '#1890ff'
                                }}>
                                  <strong>Optimization Summary:</strong> {optimizationResult.totalCombinations} valid combinations tested. 
                                  Best Sharpe Ratio: {optimizationResult.bestCombination.sharpeRatio.toFixed(2)}
                                </div>
                              </div>
                              
                              {/* Optimization Heatmap */}
                              <div style={{ marginBottom: '32px' }}>
                                <h5 style={{ marginBottom: '16px' }}>Optimization Heatmap</h5>
                                <div style={{ 
                                  background: 'white',
                                  borderRadius: '8px',
                                  padding: '20px',
                                  border: '1px solid #e8e8e8',
                                  display: 'flex',
                                  flexDirection: 'column',
                                  alignItems: 'center'
                                }}>
                                  <div style={{ marginBottom: '16px', fontSize: '12px', color: '#666', textAlign: 'center' }}>
                                    X-axis: Short MA (fast), Y-axis: Long MA (slow). Color represents Sharpe Ratio.
                                  </div>
                                  
                                  {(() => {
                                    // Prepare data for heatmap
                                    const results: OptimizationResultItem[] = optimizationResult.results;
                                    
                                    // Get unique short_ma and long_ma values
                                    const shortSet = new Set<number>();
                                    const longSet = new Set<number>();
                                    results.forEach((r: OptimizationResultItem) => {
                                      shortSet.add(r.short_ma);
                                      longSet.add(r.long_ma);
                                    });
                                    const shortValues = Array.from(shortSet).sort((a, b) => a - b);
                                    const longValues = Array.from(longSet).sort((a, b) => a - b);
                                    
                                    // Find min and max Sharpe Ratio for color scaling
                                    const sharpeValues = results.map((r: OptimizationResultItem) => r.sharpeRatio);
                                    const minSharpe = Math.min(...sharpeValues);
                                    const maxSharpe = Math.max(...sharpeValues);
                                    const sharpeRange = maxSharpe - minSharpe;
                                    
                                    // Create a map for quick lookup
                                    const resultMap = new Map<string, OptimizationResultItem>();
                                    results.forEach((result: OptimizationResultItem) => {
                                      resultMap.set(`${result.short_ma}_${result.long_ma}`, result);
                                    });
                                    
                                    // Function to get color based on Sharpe Ratio
                                    const getColor = (sharpe: number) => {
                                      if (sharpeRange === 0) return '#d9d9d9'; // Gray if all values are the same
                                      
                                      const normalized = (sharpe - minSharpe) / sharpeRange;
                                      
                                      // Color gradient: red (low) -> yellow (medium) -> green (high)
                                      if (normalized < 0.5) {
                                        // Red to Yellow
                                        const r = 255;
                                        const g = Math.round(255 * (normalized * 2));
                                        return `rgb(${r}, ${g}, 0)`;
                                      } else {
                                        // Yellow to Green
                                        const r = Math.round(255 * (1 - (normalized - 0.5) * 2));
                                        const g = 255;
                                        return `rgb(${r}, ${g}, 0)`;
                                      }
                                    };
                                    
                                    return (
                                      <div style={{ 
                                        display: 'grid',
                                        gridTemplateColumns: `auto repeat(${shortValues.length}, 1fr)`,
                                        gap: '2px',
                                        fontSize: '10px'
                                      }}>
                                        {/* Top-left empty cell */}
                                        <div style={{ 
                                          padding: '8px',
                                          textAlign: 'center',
                                          fontWeight: 'bold',
                                          background: '#fafafa'
                                        }}>
                                          Short MA â?                                        </div>
                                        
                                        {/* X-axis headers (short_ma values) */}
                                        {shortValues.map(shortVal => (
                                          <div key={`header-${shortVal}`} style={{ 
                                            padding: '8px',
                                            textAlign: 'center',
                                            fontWeight: 'bold',
                                            background: '#fafafa',
                                            borderBottom: '2px solid #1890ff'
                                          }}>
                                            {shortVal}
                                          </div>
                                        ))}
                                        
                                        {/* Heatmap rows */}
                                        {longValues.map(longVal => (
                                          <React.Fragment key={`row-${longVal}`}>
                                            {/* Y-axis header (long_ma value) */}
                                            <div style={{ 
                                              padding: '8px',
                                              textAlign: 'center',
                                              fontWeight: 'bold',
                                              background: '#fafafa',
                                              borderRight: '2px solid #1890ff'
                                            }}>
                                              {longVal}
                                            </div>
                                            
                                            {/* Heatmap cells */}
                                            {shortValues.map(shortVal => {
                                              const result = resultMap.get(`${shortVal}_${longVal}`);
                                              const hasResult = !!result;
                                              const sharpe = hasResult ? result.sharpeRatio : 0;
                                              
                                              return (
                                                <Tooltip
                                                  key={`cell-${shortVal}-${longVal}`}
                                                  title={hasResult ? (
                                                    <div style={{ fontSize: '12px', color: '#000' }}>
                                                      <div><strong>Parameters:</strong> Short MA={shortVal}, Long MA={longVal}</div>
                                                      <div><strong>Sharpe Ratio:</strong> <span style={{ color: sharpe >= 0 ? '#52c41a' : '#ff4d4f' }}>{sharpe.toFixed(2)}</span></div>
                                                      <div><strong>Total Return:</strong> <span style={{ color: result.totalReturn >= 0 ? '#52c41a' : '#ff4d4f' }}>{result.totalReturn >= 0 ? '+' : ''}{result.totalReturn.toFixed(2)}%</span></div>
                                                      <div><strong>Max Drawdown:</strong> <span style={{ color: '#ff4d4f' }}>{result.maxDrawdown.toFixed(2)}%</span></div>
                                                      <div><strong>Trades:</strong> {result.trades}</div>
                                                    </div>
                                                  ) : (
                                                    <div style={{ color: '#000' }}>No data for Short MA={shortVal}, Long MA={longVal}</div>
                                                  )}
                                                  placement="top"
                                                  color="white"
                                                  overlayStyle={{ maxWidth: '300px' }}
                                                >
                                                  <div
                                                    style={{
                                                      width: '40px',
                                                      height: '40px',
                                                      background: hasResult ? getColor(sharpe) : '#f5f5f5',
                                                      border: '1px solid #e8e8e8',
                                                      borderRadius: '2px',
                                                      cursor: hasResult ? 'pointer' : 'default',
                                                      display: 'flex',
                                                      alignItems: 'center',
                                                      justifyContent: 'center',
                                                      transition: 'transform 0.2s'
                                                    }}
                                                    onMouseEnter={(e) => {
                                                      if (hasResult) {
                                                        e.currentTarget.style.transform = 'scale(1.1)';
                                                        e.currentTarget.style.zIndex = '1';
                                                        e.currentTarget.style.boxShadow = '0 2px 8px rgba(0,0,0,0.15)';
                                                      }
                                                    }}
                                                    onMouseLeave={(e) => {
                                                      if (hasResult) {
                                                        e.currentTarget.style.transform = 'scale(1)';
                                                        e.currentTarget.style.zIndex = '0';
                                                        e.currentTarget.style.boxShadow = 'none';
                                                      }
                                                    }}
                                                  >
                                                    {hasResult && (
                                                      <span style={{
                                                        color: sharpe >= 0 ? '#000' : '#fff',
                                                        fontWeight: 'bold',
                                                        fontSize: '9px'
                                                      }}>
                                                        {sharpe.toFixed(1)}
                                                      </span>
                                                    )}
                                                  </div>
                                                </Tooltip>
                                              );
                                            })}
                                          </React.Fragment>
                                        ))}
                                        
                                        {/* Color legend */}
                                        <div style={{ 
                                          gridColumn: `1 / span ${shortValues.length + 1}`,
                                          marginTop: '16px',
                                          paddingTop: '16px',
                                          borderTop: '1px solid #e8e8e8'
                                        }}>
                                          <div style={{ fontSize: '11px', color: '#666', marginBottom: '8px' }}>
                                            Color Legend (Sharpe Ratio):
                                          </div>
                                          <div style={{ 
                                            display: 'flex',
                                            alignItems: 'center',
                                            gap: '8px',
                                            fontSize: '10px'
                                          }}>
                                            <div style={{ display: 'flex', alignItems: 'center' }}>
                                              <div style={{ width: '20px', height: '20px', background: 'rgb(255, 0, 0)', border: '1px solid #ccc' }}></div>
                                              <span style={{ marginLeft: '4px' }}>Low ({minSharpe.toFixed(2)})</span>
                                            </div>
                                            <div style={{ display: 'flex', alignItems: 'center' }}>
                                              <div style={{ width: '20px', height: '20px', background: 'rgb(255, 255, 0)', border: '1px solid #ccc' }}></div>
                                              <span style={{ marginLeft: '4px' }}>Medium</span>
                                            </div>
                                            <div style={{ display: 'flex', alignItems: 'center' }}>
                                              <div style={{ width: '20px', height: '20px', background: 'rgb(0, 255, 0)', border: '1px solid #ccc' }}></div>
                                              <span style={{ marginLeft: '4px' }}>High ({maxSharpe.toFixed(2)})</span>
                                            </div>
                                            <div style={{ display: 'flex', alignItems: 'center', marginLeft: '16px' }}>
                                              <div style={{ width: '20px', height: '20px', background: '#f5f5f5', border: '1px solid #ccc' }}></div>
                                              <span style={{ marginLeft: '4px' }}>No data</span>
                                            </div>
                                          </div>
                                        </div>
                                      </div>
                                    );
                                  })()}
                                </div>
                              </div>
                              
                              {/* Results Table */}
                              <div style={{ marginBottom: '24px' }}>
                                <h5 style={{ marginBottom: '16px' }}>Optimization Results</h5>
                                <Table
                                  dataSource={optimizationResult.results}
                                  columns={[
                                    {
                                      title: 'Short MA',
                                      dataIndex: 'short_ma',
                                      key: 'short_ma',
                                      width: 100,
                                      sorter: (a: OptimizationResultItem, b: OptimizationResultItem) => a.short_ma - b.short_ma,
                                    },
                                    {
                                      title: 'Long MA',
                                      dataIndex: 'long_ma',
                                      key: 'long_ma',
                                      width: 100,
                                      sorter: (a: OptimizationResultItem, b: OptimizationResultItem) => a.long_ma - b.long_ma,
                                    },
                                    {
                                      title: 'Sharpe Ratio',
                                      dataIndex: 'sharpeRatio',
                                      key: 'sharpeRatio',
                                      width: 120,
                                      sorter: (a: OptimizationResultItem, b: OptimizationResultItem) => a.sharpeRatio - b.sharpeRatio,
                                      defaultSortOrder: 'descend',
                                      render: (value: number) => (
                                        <span style={{ 
                                          color: value >= 0 ? '#52c41a' : '#ff4d4f',
                                          fontWeight: 'bold'
                                        }}>
                                          {value.toFixed(2)}
                                        </span>
                                      ),
                                    },
                                    {
                                      title: 'Total Return',
                                      dataIndex: 'totalReturn',
                                      key: 'totalReturn',
                                      width: 120,
                                      sorter: (a: OptimizationResultItem, b: OptimizationResultItem) => a.totalReturn - b.totalReturn,
                                      render: (value: number) => (
                                        <span style={{ 
                                          color: value >= 0 ? '#52c41a' : '#ff4d4f',
                                          fontWeight: 'bold'
                                        }}>
                                          {value >= 0 ? '+' : ''}{value.toFixed(2)}%
                                        </span>
                                      ),
                                    },
                                    {
                                      title: 'Max Drawdown',
                                      dataIndex: 'maxDrawdown',
                                      key: 'maxDrawdown',
                                      width: 120,
                                      sorter: (a: OptimizationResultItem, b: OptimizationResultItem) => a.maxDrawdown - b.maxDrawdown,
                                      render: (value: number) => (
                                        <span style={{ 
                                          color: '#ff4d4f',
                                          fontWeight: 'bold'
                                        }}>
                                          {value.toFixed(2)}%
                                        </span>
                                      ),
                                    },
                                    {
                                      title: 'Trades',
                                      dataIndex: 'trades',
                                      key: 'trades',
                                      width: 100,
                                      sorter: (a: OptimizationResultItem, b: OptimizationResultItem) => a.trades - b.trades,
                                      render: (value: number) => (
                                        <span style={{ fontWeight: 'bold' }}>
                                          {value}
                                        </span>
                                      ),
                                    },
                                  ]}
                                  size="small"
                                  pagination={{
                                    pageSize: 10,
                                    showSizeChanger: true,
                                    showQuickJumper: true,
                                    showTotal: (total) => `Total ${total} combinations`,
                                  }}
                                  rowKey={(record: OptimizationResultItem) => `${record.short_ma}_${record.long_ma}`}
                                />
                              </div>
                              
                              <Divider />
                            </div>
                          )}
                          
                          {/* Monthly Return Heatmap */}
                {backtestResult?.results?.monthlyReturns && backtestResult.results.monthlyReturns.length > 0 && (
                  <>
                    <h4 style={{ marginTop: '32px', marginBottom: '16px' }}>Monthly Return Heatmap</h4>
                    <div style={{ 
                      background: 'white',
                      borderRadius: '8px',
                      padding: '16px',
                      border: '1px solid #e8e8e8'
                    }}>
                      <div style={{ 
                        display: 'grid',
                        gridTemplateColumns: 'auto repeat(12, 1fr)',  // 13åïž1ååđīäŧ―æ į­?+ 12åæäŧ?                        gap: '8px',
                        marginBottom: '16px'
                      }}>
                        {/* įŽ?čĄïžįĐšååæ žïžįŽŽ1åïž + æäŧ―æ éĒïžįŽŽ2-13åïž */}
                        <div style={{ 
                          gridColumn: '1',
                          textAlign: 'right',
                          fontSize: '11px',
                          fontWeight: '500',
                          color: '#666',
                          padding: '4px 8px 4px 0'
                        }}>
                          {/* åđīäŧ―æ į­ūå ä―įŽ?*/}
                        </div>
                        
                        {/* æäŧ―æ éĒïžįŽŽ2-13åïž */}
                        {['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'].map((month, index) => (
                          <div 
                            key={month}
                            style={{ 
                              textAlign: 'center', 
                              fontSize: '11px',
                              fontWeight: '500',
                              color: '#666',
                              padding: '4px 0',
                              gridColumn: `${index + 2}`  // äŧįŽŽ2ååžå§?                            }}
                          >
                            {month}
                          </div>
                        ))}
                        
                        {/* åđīäŧ―čĄïžįŽ?čĄåžå§ïž */}
                        {(() => {
                          // Group monthly returns by year
                          const returnsByYear: { [year: number]: any[] } = {};
                          backtestResult.results.monthlyReturns.forEach(item => {
                            if (!returnsByYear[item.year]) {
                              returnsByYear[item.year] = new Array(12).fill(null);
                            }
                            returnsByYear[item.year][item.month - 1] = item;
                          });
                          
                          // Get sorted years
                          const years = Object.keys(returnsByYear).map(Number).sort();
                          
                          return years.map((year, rowIndex) => (
                            <React.Fragment key={year}>
                              {/* åđīäŧ―æ į­ūïžįŽŽ1åïž */}
                              <div style={{ 
                                gridColumn: '1',
                                display: 'flex',
                                alignItems: 'center',
                                justifyContent: 'flex-end',
                                fontSize: '12px',
                                fontWeight: '500',
                                color: '#666',
                                paddingRight: '8px',
                                gridRow: `${rowIndex + 2}`  // äŧįŽŽ2čĄåžå§?                              }}>
                                {year}
                              </div>
                              
                              {/* æäŧ―ååæ žïžįŽ?-13åïž */}
                              {returnsByYear[year].map((item, monthIndex) => {
                                const month = monthIndex + 1;
                                const returnValue = item?.return || 0;
                                
                                // Determine color based on return value - Standard heatmap colors
                                let backgroundColor = '#f5f5f5'; // Default for no data
                                let textColor = '#666';
                                
                                if (item) {
                                  if (returnValue > 10) {
                                    // > +10%: Dark green
                                    backgroundColor = '#006400';
                                    textColor = '#ffffff';
                                  } else if (returnValue > 0) {
                                    // 0~10%: Light green
                                    backgroundColor = '#90ee90';
                                    textColor = '#006400';
                                  } else if (returnValue === 0) {
                                    // 0%: Gray
                                    backgroundColor = '#d3d3d3';
                                    textColor = '#666';
                                  } else if (returnValue > -10) {
                                    // 0~-10%: Light red
                                    backgroundColor = '#ffb6c1';
                                    textColor = '#8b0000';
                                  } else {
                                    // < -10%: Dark red
                                    backgroundColor = '#8b0000';
                                    textColor = '#ffffff';
                                  }
                                }
                                
                                return (
                                  <Tooltip 
                                    key={`${year}-${month}`}
                                    title={
                                      <div style={{ textAlign: 'center' }}>
                                        <div style={{ fontWeight: 'bold' }}>{item ? `${item.monthName} ${year}` : 'No data'}</div>
                                        {item && (
                                          <div>Return: {returnValue > 0 ? '+' : ''}{returnValue.toFixed(2)}%</div>
                                        )}
                                      </div>
                                    }
                                    placement="top"
                                  >
                                    <div
                                      style={{
                                        display: 'flex',
                                        alignItems: 'center',
                                        justifyContent: 'center',
                                        height: '32px',
                                        borderRadius: '4px',
                                        backgroundColor,
                                        color: textColor,
                                        fontSize: '11px',
                                        fontWeight: '500',
                                        cursor: 'pointer',
                                        transition: 'all 0.2s',
                                        position: 'relative',
                                        gridColumn: `${monthIndex + 2}`,  // įŽ?-13å?                                        gridRow: `${rowIndex + 2}`        // äŧįŽŽ2čĄåžå§?                                      }}
                                      onMouseEnter={(e) => {
                                        e.currentTarget.style.transform = 'scale(1.05)';
                                        e.currentTarget.style.boxShadow = '0 2px 8px rgba(0,0,0,0.1)';
                                      }}
                                      onMouseLeave={(e) => {
                                        e.currentTarget.style.transform = 'scale(1)';
                                        e.currentTarget.style.boxShadow = 'none';
                                      }}
                                    >
                                      {item ? (
                                        <>
                                          <span>{returnValue > 0 ? '+' : ''}{returnValue.toFixed(2)}%</span>
                                          <div style={{
                                            position: 'absolute',
                                            bottom: '2px',
                                            left: '2px',
                                            right: '2px',
                                            height: '2px',
                                            backgroundColor: returnValue > 0 ? '#52c41a' : returnValue < 0 ? '#ff4d4f' : '#d9d9d9',
                                            borderRadius: '1px'
                                          }} />
                                        </>
                                      ) : (
                                        <span style={{ color: '#bfbfbf' }}>-</span>
                                      )}
                                    </div>
                                  </Tooltip>
                                );
                              })}
                            </React.Fragment>
                          ));
                        })()}
                      </div>
                      
                      {/* Legend */}
                      <div style={{ 
                        display: 'flex', 
                        alignItems: 'center', 
                        justifyContent: 'center',
                        gap: '12px',
                        fontSize: '10px',
                        color: '#666',
                        marginTop: '8px',
                        flexWrap: 'wrap'
                      }}>
                        <div style={{ display: 'flex', alignItems: 'center', gap: '4px' }}>
                          <div style={{ width: '10px', height: '10px', backgroundColor: '#006400', borderRadius: '2px' }}></div>
                          <span>&gt; +10%</span>
                        </div>
                        <div style={{ display: 'flex', alignItems: 'center', gap: '4px' }}>
                          <div style={{ width: '10px', height: '10px', backgroundColor: '#90ee90', borderRadius: '2px' }}></div>
                          <span>0% to +10%</span>
                        </div>
                        <div style={{ display: 'flex', alignItems: 'center', gap: '4px' }}>
                          <div style={{ width: '10px', height: '10px', backgroundColor: '#d3d3d3', borderRadius: '2px' }}></div>
                          <span>0%</span>
                        </div>
                        <div style={{ display: 'flex', alignItems: 'center', gap: '4px' }}>
                          <div style={{ width: '10px', height: '10px', backgroundColor: '#ffb6c1', borderRadius: '2px' }}></div>
                          <span>-10% to 0%</span>
                        </div>
                        <div style={{ display: 'flex', alignItems: 'center', gap: '4px' }}>
                          <div style={{ width: '10px', height: '10px', backgroundColor: '#8b0000', borderRadius: '2px' }}></div>
                          <span>&lt; -10%</span>
                        </div>
                        <div style={{ display: 'flex', alignItems: 'center', gap: '4px' }}>
                          <div style={{ width: '10px', height: '10px', backgroundColor: '#f5f5f5', borderRadius: '2px', border: '1px solid #d9d9d9' }}></div>
                          <span>No Data</span>
                        </div>
                      </div>
                      
                      {/* Summary statistics */}
                      <div style={{ 
                        marginTop: '16px',
                        paddingTop: '16px',
                        borderTop: '1px solid #f0f0f0',
                        fontSize: '12px',
                        color: '#666'
                      }}>
                        <div style={{ display: 'flex', flexDirection: 'column', gap: '10px' }}>
                          <div style={{ display: 'flex', alignItems: 'flex-start' }}>
                            <span style={{ minWidth: '140px', fontWeight: '500' }}>æä―ģæäŧ?</span>
                            <strong style={{ color: '#3f8600' }}>
                              {(() => {
                                if (!backtestResult.results.monthlyReturns || backtestResult.results.monthlyReturns.length === 0) {
                                  return 'N/A';
                                }
                                // Find best month (highest return)
                                const bestMonth = backtestResult.results.monthlyReturns.reduce((best, current) => {
                                  return current.return > best.return ? current : best;
                                });
                                return `${bestMonth.monthName} ${bestMonth.year}: +${bestMonth.return.toFixed(2)}%`;
                              })()}
                            </strong>
                          </div>
                          <div style={{ display: 'flex', alignItems: 'flex-start' }}>
                            <span style={{ minWidth: '140px', fontWeight: '500' }}>æå·Ūæäŧ?</span>
                            <strong style={{ color: '#cf1322' }}>
                              {(() => {
                                if (!backtestResult.results.monthlyReturns || backtestResult.results.monthlyReturns.length === 0) {
                                  return 'N/A';
                                }
                                // Find worst month (lowest return) - use explicit comparison
                                const worstMonth = backtestResult.results.monthlyReturns.reduce((worst, current) => {
                                  return current.return < worst.return ? current : worst;
                                });
                                return `${worstMonth.monthName} ${worstMonth.year}: ${worstMonth.return.toFixed(2)}%`;
                              })()}
                            </strong>
                          </div>
                          <div style={{ display: 'flex', alignItems: 'flex-start' }}>
                            <span style={{ minWidth: '140px', fontWeight: '500' }}>åđģåææķįį:</span>
                            <strong>
                              {(() => {
                                if (!backtestResult.results.monthlyReturns || backtestResult.results.monthlyReturns.length === 0) {
                                  return 'N/A';
                                }
                                const avgReturn = backtestResult.results.monthlyReturns
                                  .reduce((sum, item) => sum + item.return, 0) / backtestResult.results.monthlyReturns.length;
                                const color = avgReturn > 0 ? '#3f8600' : avgReturn < 0 ? '#cf1322' : '#666';
                                return <span style={{ color }}>{avgReturn > 0 ? '+' : ''}{avgReturn.toFixed(2)}%</span>;
                              })()}
                            </strong>
                          </div>
                        </div>
                      </div>
                    </div>
                  </>
                )}

                {/* Rolling Sharpe Ratio */}
                {backtestResult?.results?.rollingSharpeRatio && backtestResult.results.rollingSharpeRatio.length > 0 && (
                  <>
                    <h4 style={{ marginTop: '32px', marginBottom: '16px' }}>Rolling Sharpe Ratio (30-day)</h4>
                    <div style={{ 
                      height: '200px', 
                      background: 'white',
                      borderRadius: '8px',
                      padding: '16px',
                      border: '1px solid #e8e8e8'
                    }}>
                      <ResponsiveContainer width="100%" height="100%">
                        <LineChart
                          data={backtestResult.results.rollingSharpeRatio}
                          margin={{ top: 5, right: 5, left: 5, bottom: 5 }}
                        >
                          <CartesianGrid strokeDasharray="3 3" stroke="#f0f0f0" />
                          <XAxis 
                            dataKey="date" 
                            tick={{ fontSize: 10 }}
                            tickFormatter={(value) => {
                              // Format date to show only month/day for better readability
                              try {
                                const date = new Date(value);
                                return `${date.getMonth() + 1}/${date.getDate()}`;
                              } catch {
                                return value;
                              }
                            }}
                          />
                          <YAxis 
                            tick={{ fontSize: 10 }}
                            tickFormatter={(value) => value.toFixed(2)}
                            label={{ 
                              value: 'Sharpe Ratio', 
                              angle: -90, 
                              position: 'insideLeft',
                              style: { fontSize: '11px', fill: '#666' }
                            }}
                          />
                          <RechartsTooltip 
                            formatter={(value, name) => {
                              if (name === 'sharpe') return [Number(value).toFixed(3), 'Sharpe Ratio'];
                              return [value, name];
                            }}
                            labelFormatter={(label) => `Date: ${label}`}
                          />
                          <Line
                            type="monotone"
                            dataKey="sharpe"
                            stroke="#1890ff"
                            strokeWidth={2}
                            dot={false}
                            activeDot={{ r: 4, strokeWidth: 1 }}
                            name="sharpe"
                          />
                        </LineChart>
                      </ResponsiveContainer>
                    </div>
                  </>
                )}

                {/* Equity Curve */}
                <h4 style={{ marginTop: '32px', marginBottom: '16px' }}>Equity Curve</h4>
                {equityCurveData.length > 0 ? (
                  <div style={{ 
                    height: '150px', 
                    background: '#fafafa',
                    borderRadius: '8px',
                    padding: '16px',
                    position: 'relative'
                  }}>
                    <div style={{ 
                      display: 'flex', 
                      alignItems: 'flex-end', 
                      height: '100px',
                      justifyContent: 'space-between',
                      marginBottom: '8px'
                    }}>
                      {equityCurveData.map((point, index) => {
                        const prices = equityCurveData.map(p => p.equity);
                        const maxPrice = Math.max(...prices);
                        const minPrice = Math.min(...prices);
                        const price = point.equity;
                        const heightPercent = ((price - minPrice) / (maxPrice - minPrice)) * 100;
                        
                        return (
                          <div
                            key={index}
                            style={{
                              width: '8%',
                              height: `${Math.max(heightPercent, 5)}%`,
                              backgroundColor: price >= equityCurveData[0].equity ? '#3f8600' : '#cf1322',
                              borderRadius: '2px',
                              position: 'relative'
                            }}
                            title={`${point.date}: $${safeToFixed(price, 2)}`}
                          />
                        );
                      })}
                    </div>
                    
                    <div style={{ 
                      display: 'flex', 
                      justifyContent: 'space-between',
                      fontSize: '10px',
                      color: '#666'
                    }}>
                      <span>{equityCurveData[0]?.date || 'Start'}</span>
                      <span>Equity Curve</span>
                      <span>{equityCurveData[equityCurveData.length - 1]?.date || 'End'}</span>
                    </div>
                  </div>
                ) : (
                  <div style={{ textAlign: 'center', padding: '40px', color: '#999' }}>
                    No equity curve data available
                  </div>
                )}

                {/* Drawdown Chart */}
                <h4 style={{ marginTop: '32px', marginBottom: '16px' }}>Drawdown Chart</h4>
                <DrawdownChart 
                  data={drawdownData}
                  equityData={equityCurveData}  // äž é?equity æ°æŪįĻäš tooltip
                  height={200}
                />

                {/* Trade Log */}
                {backtestResult?.results?.tradesList && backtestResult.results.tradesList.length > 0 && (
                  <>
                    <h4 style={{ marginTop: '32px', marginBottom: '16px' }}>Trade Log</h4>
                    <TradeLogTable data={backtestResult.results.tradesList} />
                  </>
                )}
                        </>
                      ),
                    },
                    {
                      key: 'chart',
                      label: 'Trading Chart',
                      children: backtestResult?.results?.chartData ? (
                        <TradingChart
                          data={backtestResult.results.chartData}
                          height={500}
                          parameters={{
                            strategy: backtestResult.parameters?.strategy,
                            symbol: backtestResult.parameters?.symbols?.[0],
                            period: backtestResult.parameters?.period,
                            initialCapital: backtestResult.parameters?.initialCapital
                          }}
                        />
                      ) : (
                        <Empty 
                          description="No chart data available" 
                          image={Empty.PRESENTED_IMAGE_SIMPLE}
                          style={{ padding: '40px 0' }}
                        />
                      ),
                    },
                  ]}
                />
                
                <Divider />
                
                <h4>Parameters</h4>
                <Row gutter={16}>
                  <Col span={6}>
                    <div><strong>Strategy:</strong> {backtestResult.parameters?.strategy || 'Unknown'}</div>
                  </Col>
                  <Col span={6}>
                    <div><strong>Symbols:</strong> {backtestResult.parameters?.symbols?.join(', ') || 'Unknown'}</div>
                  </Col>
                  <Col span={6}>
                    <div><strong>Period:</strong> {backtestResult.parameters?.period || 'Unknown'}</div>
                  </Col>
                  <Col span={6}>
                    <div><strong>Initial Capital:</strong> ${safeNumber(backtestResult.parameters?.initialCapital).toLocaleString()}</div>
                  </Col>
                </Row>
              </Card>
            </div>
          )}
        </Col>
        
        <Col span={8}>
          <Card 
            title="Recent Backtests" 
            extra={
              <Space>
                {selectedBacktests.length > 0 && (
                  <Button 
                    type="primary" 
                    size="small"
                    onClick={() => {
                      if (selectedBacktests.length > 0) {
                        navigate(`/compare?ids=${selectedBacktests.join(',')}`);
                      } else {
                        message.warning('Please select at least one backtest to compare');
                      }
                    }}
                  >
                    Compare ({selectedBacktests.length})
                  </Button>
                )}
                <Button 
                  type="text" 
                  icon={<ReloadOutlined />} 
                  onClick={fetchBacktestHistory}
                  loading={historyLoading}
                  size="small"
                />
              </Space>
            }
          >
            {historyLoading ? (
              <div style={{ textAlign: 'center', padding: '40px' }}>
                <Spin />
              </div>
            ) : backtestHistory.length > 0 ? (
              <Table
                columns={historyColumns}
                dataSource={backtestHistory}
                rowKey="backtestId"
                pagination={{ pageSize: 5, simple: true }}
                size="small"
                scroll={{ y: 300 }}
              />
            ) : (
              <Empty
                image={Empty.PRESENTED_IMAGE_SIMPLE}
                description="No backtest history yet"
              >
                <Button type="primary" onClick={() => {
                  form.setFieldsValue({
                    symbol: 'AAPL',
                    strategy: 'moving_average',
                    initialCapital: 100000,
                    dateRange: defaultDateRange()
                  });
                  message.info('AAPL example loaded');
                }}>
                  Try AAPL Example
                </Button>
              </Empty>
            )}
          </Card>
          
          <Card title="Quick Actions" style={{ marginTop: 16 }}>
            <Space direction="vertical" style={{ width: '100%' }}>
              <Button 
                type="default" 
                block
                onClick={() => navigate('/market')}
                icon={<LineChartOutlined />}
              >
                Browse Market
              </Button>
              <Button 
                type="default" 
                block
                onClick={() => {
                  form.setFieldsValue({
                    symbol: 'AAPL',
                    strategy: 'moving_average',
                    initialCapital: 100000,
                    dateRange: defaultDateRange()
                  });
                  message.info('AAPL example loaded');
                }}
              >
                Load AAPL Example
              </Button>
              <Button 
                type="default" 
                block
                onClick={() => {
                  form.setFieldsValue({
                    symbol: 'MSFT',
                    strategy: 'rsi',
                    initialCapital: 50000,
                    dateRange: defaultDateRange()
                  });
                  message.info('MSFT example loaded');
                }}
              >
                Load MSFT Example
              </Button>
              <Button 
                type="default" 
                block
                onClick={() => {
                  form.setFieldsValue({
                    symbol: 'TSLA',
                    strategy: 'momentum',
                    initialCapital: 75000,
                    dateRange: defaultDateRange()
                  });
                  message.info('TSLA example loaded');
                }}
              >
                Load TSLA Example
              </Button>
            </Space>
          </Card>
        </Col>
      </Row>
    </div>
  );
};

export default Backtest;
