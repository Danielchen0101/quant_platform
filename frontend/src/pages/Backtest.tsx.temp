              </Tooltip>
            );
          })}
        </React.Fragment>
      ))}
      
      {/* Color legend */}
      <div style={{ 
        gridColumn: `1 / span ${shortValues.length + 1}`,
        marginTop: '16px',
        paddingTop: '16px',
        borderTop: '1px solid #e8e8e8'
